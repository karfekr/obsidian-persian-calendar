{
  "name": "obsidian-persian-calendar",
  "version": "4.5.12",
  "description": "Persian/Jalali calendar integration featuring dynamic note paths, placeholders, API access, and event display.",
  "main": "main.js",
  "scripts": {
    "prepare": "node scripts/clean.mjs",
    "version": "node scripts/sync-version.mjs",
    "test": "vitest",
    "dev": "node esbuild.config.mjs && node scripts/build-styles.mjs --watch",
    "build": "node scripts/clean.mjs && node scripts/build-styles.mjs && node esbuild.config.mjs production && node scripts/sync-version.mjs && tsc -noEmit -skipLibCheck"
  },
  "keywords": [],
  "packageManager": "pnpm@11.2.2",
  "author": {
    "name": "Hossein Maleknejad",
    "url": "http://karfekr.ir"
  },
  "contributors": [
    {
      "name": "Muhammadhussein Ammari",
      "url": "https://github.com/xmha97"
    },
    {
      "name": "Alireza Mohammadzadeh(NedaMani)",
      "url": "https://nedamani.ir"
    }
  ],
  "repository": "https://github.com/karfekr/obsidian-persian-calendar",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "8.51.0",
    "@typescript-eslint/parser": "8.51.0",
    "chokidar": "^5.0.0",
    "cssnano": "^7.1.9",
    "esbuild": "0.27.2",
    "obsidian": "1.13.1",
    "postcss": "^8.5.15",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.2"
  }
}
