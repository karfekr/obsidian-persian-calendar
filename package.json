			"name": "Alireza Mohammadzadeh(NedaMani)",
			"url": "https://nedamani.ir"
		}
	],
	"repository": "https://github.com/karfekr/obsidian-persian-calendar",
	"license": "GPL-3.0-only",
	"devDependencies": {
		"@types/node": "^25.0.3",
		"@typescript-eslint/eslint-plugin": "8.51.0",
		"@typescript-eslint/parser": "8.51.0",
		"chokidar": "^5.0.0",
		"cssnano": "^7.1.2",
		"esbuild": "0.27.2",
		"obsidian": "latest",
		"postcss": "^8.5.6",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@internationalized/date": "^3.11.0"
	}
}
