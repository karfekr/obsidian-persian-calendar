{
	"name": "obsidian-persian-calendar",
	"version": "4.5.9",
	"description": "Persian/Jalali calendar integration featuring dynamic note paths, placeholders, API access, and event display.",
	"main": "main.js",
	"scripts": {
		"prepare": "node scripts/clean.mjs",
		"version": "node scripts/sync-version.mjs",
		"test": "vitest",
		"dev": "node esbuild.config.mjs && node scripts/build-styles.mjs --watch",
		"build": "node scripts/clean.mjs && node scripts/build-styles.mjs && node esbuild.config.mjs production && node scripts/sync-version.mjs && tsc -noEmit -skipLibCheck"
	},
	"keywords": [],
